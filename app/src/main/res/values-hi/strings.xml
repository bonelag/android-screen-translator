  <string name="message_permission_notification_detail">स्क्रीन अनुवादक लॉन्च करने के लिए, आपको सूचना की अनुमति देनी होगी।</string>

  <!-- Overlay Permission -->
  <string name="message_permission_overlay">आवश्यक अनुमति:\nअन्य ऐप्स के ऊपर दिखाएं</string>
  <string name="message_permission_overlay_detail">स्क्रीन अनुवादक लॉन्च करने के लिए, आपको अन्य ऐप्स के ऊपर प्रदर्शित करने की अनुमति देनी होगी।</string>
  <string name="message_permission_overlay_denied">ओवरले अनुमति अस्वीकृत</string>
  <string name="message_permission_overlay_denied_detail">ओवरले अनुमति नहीं दी गई है।\nऐप बंद किया जाएगा।</string>

  <!-- MediaProjection token 요청 -->
  <string name="message_media_projection">आवश्यक अनुमति:\nस्क्रीन रिकॉर्डिंग</string>
  <string name="message_media_projection_detail">स्क्रीन अनुवादक लॉन्च करने के लिए, आपको स्क्रीन रिकॉर्डिंग की अनुमति देनी होगी।\n\nस्क्रीन की जानकारी केवल अनुवाद के उद्देश्य के लिए उपयोग की जाएगी और कहीं और स्थानांतरित या संग्रहीत नहीं की जाएगी।</string>
  <string name="message_media_projection_denied">स्क्रीन रिकॉर्डिंग अनुमति अस्वीकृत</string>
  <string name="message_media_projection_denied_detail">स्क्रीन रिकॉर्डिंग की अनुमति नहीं दी गई है।\nऐप बंद किया जाएगा।</string>

  <!-- Foreground Service 시작 알림 -->
  <string name="notification_foreground_service">अनुवाद कार्य के लिए स्क्रीन कैप्चर फ़ंक्शन का उपयोग किया जा रहा है।</string>
