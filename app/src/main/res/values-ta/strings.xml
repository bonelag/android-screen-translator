    <string name="premium_view_get_premium_pending">உங்கள் பிரீமியம் நன்மைகள் (நிலுவையில்)</string>
    <string name="premium_view_get_premium_not_available">பிரீமியம் பெறுதல் (தற்போது கிடைக்கவில்லை)</string>
    <string name="premium_view_price_format">%1$s/மாதம் • VAT உட்பட\n• எப்போது வேண்டுமானாலும் ரத்து செய்யலாம்</string>
    <string name="premium_view_title">அனைத்து அம்சங்கள்,\nதடையில்லாமல்.</string>
    <string name="premium_view_message">அளவிலும் காலத்திலும் வரம்பில்லை.\nபிரீமியம் மூலம் அனைத்தும் வரம்பில்லாது கிடைக்கும்.</string>
    <string name="premium_view_description_azure">உலகின் பெரும்பாலான மொழிகளை துல்லியமாக மொழிபெயர்க்கிறது.</string>
    <string name="premium_view_description_deepl">அர்த்தத்தை மிக நன்றாக பிடித்துவைக்கும் நுட்பமான மொழிபெயர்ப்புகளை வழங்குகிறோம்.</string>
    <string name="premium_view_description_papago">Papago மொழிபெயர்ப்பு நரம்பியல் இயந்திரம் மூலம் பல நாடுகளின் மொழிகளை இலக்கு மொழிக்கு தானாகவே மொழிபெயர்க்கிறது.</string>
    <string name="premium_view_description_google">மிக விரைவான மொழிபெயர்ப்பு. முடிவில்லாமல் இலவசம்.</string>
    <string name="premium_view_description_sentence_detection">கோடுகளை விரலால் தேர்ந்தெடுத்து மொழிபெயர்க்கலாம்.</string>
    <string name="premium_view_description_paragraph_detection">பத்தி அளவுகள் தானாக அடையாளம் காணப்படும்.</string>
    <string name="premium_view_description_select_detection">நீங்கள் விரும்பும் பகுதியை தேர்ந்தெடுக்கலாம்.</string>
    <string name="premium_view_description_word_detection">சொல்லுக்கு சொல்லாக மொழிபெயர்ப்பு எப்போதும் இலவசம் மற்றும் வரம்பில்லாது.</string>
    <string name="premium_view_description_fixed_area_detection">திரைப்பட வசன வரிகள் போன்ற நிலையான பகுதிகளை நீங்கள் தொடர்ச்சியாக மொழிபெயர்க்கலாம்.</string>
