    <string name="message_translate_fixedarea_promotion_detail">எங்கள் பிரீமியம் அம்சங்களைப் பற்றி நண்பனாக நினைவூட்டல் ஒவ்வொரு %1$s நிமிடத்திற்கும் தோன்றும்.</string>
    <string name="message_free_trial_ends">உங்கள் இலவச டிரயல் முடிந்துவிட்டது.</string>
    <string name="message_free_trial_ends_detail">டிரயலை நீட்டுவதற்காக விளம்பரம் பார்க்க விரும்புகிறீர்களா?</string>
    <string name="message_ad_reward">நீங்கள் கூடுதல் %1$d நிமிடங்கள் இலவச ட்ரையல் பெற்றுள்ளீர்கள்!</string>
