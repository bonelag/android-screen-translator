    <string name="message_playstore_update_required_detail">Play Store சேவையை இணைக்க முடியவில்லை.\nஇது சாதனத்தில் பழைய பதிப்பு இருக்கக்கூடும் என்பதற்காக இருக்கலாம்.</string>
    <string name="message_unknown_source">இந்த பயன்பாட்டைப் Play-இல் பெறுங்கள்</string>
    <string name="message_unknown_source_detail">இந்த சிறந்த பயன்பாட்டைப் பயன்படுத்த தொடர, Google Play-இல் இருந்து பெறுங்கள்.</string>
    <string name="message_force_update">புதுப்பிப்பு தேவை</string>
    <string name="message_force_update_detail">இந்த பதிப்பு இனி ஆதரிக்கப்படாது.\nStore-க்கு செல்லவும்.</string>
