    <string name="message_network_unavailable_detail">நெட்வொர்க் இல்லை.\nதயவுசெய்து சரிபார்த்து மீண்டும் முயற்சிக்கவும்.</string>
    <string name="message_translate_fixedarea_warn">மின்கலன் எச்சரிக்கை</string>
    <string name="message_translate_fixedarea_warn_detail">மின்கலன் விரைவாக தீரலாம்.</string>
