    <string name="message_permission_notification_detail">Screen Translator ஐ தொடங்க, அறிவிப்புகளுக்கான அனுமதியை வழங்க வேண்டும்.</string>

    <!-- Overlay Permission -->
    <string name="message_permission_overlay">தேவையான அனுமதி:\nமற்ற பயன்பாடுகளின் மீது காட்டவும்</string>
    <string name="message_permission_overlay_detail">Screen Translator ஐ தொடங்க, மற்ற பயன்பாடுகளின் மீது காட்ட அனுமதி தேவை.</string>
    <string name="message_permission_overlay_denied">ஓவர்லே அனுமதி மறுக்கப்பட்டது</string>
    <string name="message_permission_overlay_denied_detail">ஓவர்லே அனுமதி வழங்கப்படவில்லை.\nபயன்பாடு முடிக்கப்படும்.</string>

    <!-- MediaProjection token 요청 -->
    <string name="message_media_projection">தேவையான அனுமதி:\nதிரை பதிவுதல்</string>
    <string name="message_media_projection_detail">Screen Translator ஐ தொடங்க, திரையை பதிவு செய்ய அனுமதி தேவை.\n\nதிரையில் உள்ள தகவல்கள் மொழிபெயர்ப்புக்காக மட்டுமே பயன்படுத்தப்படும்; அவை சேமிக்கப்படவோ பகிரப்படவோ கூடாது.</string>
    <string name="message_media_projection_denied">திரை பதிவு அனுமதி மறுக்கப்பட்டது</string>
    <string name="message_media_projection_denied_detail">திரை பதிவு அனுமதி வழங்கப்படவில்லை.\nபயன்பாடு முடிக்கப்படும்.</string>

    <!-- Foreground Service 시작 알림 -->
    <string name="notification_foreground_service">மொழிபெயர்ப்பு பணிக்காக திரைப் பிடிப்பு செயல்பாடு பயன்படுத்தப்படுகிறது.</string>
    <string name="title_start_foreground_service">முன்னணி சேவையை தொடங்குகிறது</string>
    <string name="message_start_foreground_service">திரையின் உள்ளடக்கத்தை பிடித்து மொழிபெயர்ப்பதற்காக பயன்பாடு முன்னணி சேவையை தொடங்குகிறது.\n\nபிடிக்கப்பட்ட படங்கள் சேமிக்கப்படவோ வெளியில் அனுப்பப்படவோ கூடாது.</string>
    <string name="label_confirm_start_foreground_service">தொடங்கு</string>
    <string name="label_dismiss_start_foreground_service">முடி</string>
    <string name="snack_message_start_foreground_service">திரையின் உள்ளடக்கத்தை பிடித்து மொழிபெயர்ப்பதற்காக பயன்பாடு முன்னணி சேவையை தொடங்குகிறது.</string>

